NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/d360

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=30d

# WhatsApp Business API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=d360_wa_verify_token

# Facebook Page + Lead Ads + Messenger (same Meta app recommended)
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
FACEBOOK_VERIFY_TOKEN=d360_fb_verify_token
FACEBOOK_LEAD_FORM_ID=your_lead_form_id
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret

# Auto-created leads from Meta/WhatsApp go under this tenant/user
META_DEFAULT_TENANT_ID=6a077f67b28c9045e705cf00
META_DEFAULT_USER_ID=6a077f67b28c9045e705cf02

# Public HTTPS URL for Meta webhooks (ngrok / production domain)
# Example: https://abc123.ngrok-free.app
PUBLIC_WEBHOOK_BASE_URL=

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
